# Copy this file to .env and fill in your values

GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# Which origin is allowed to call this service (your Node.js backend)
AI_SERVICE_ALLOWED_ORIGIN=http://localhost:5008

# Port for this service (keep different from the Node.js backend port)
PORT=5001
